local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local NEW_NAME = ""

local function ReplaceMyName(text)
    return string.gsub(text, LocalPlayer.Name, NEW_NAME)
end

-- HOOK GLOBAL (efficace, zéro FPS drop)
if getrawmetatable then
    local mt = getrawmetatable(game)
    local old = mt.__newindex
    mt.__newindex = function(self, key, value)
        if (self:IsA("TextLabel") or self:IsA("TextButton")) and key == "Text" and type(value) == "string" then
            if string.find(value, LocalPlayer.Name) then
                value = ReplaceMyName(value)
            end
        end
        return old(self, key, value)
    end
end

-- Surveille NOUVEAUX textes (événementiel, pas de loop)
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        obj:GetPropertyChangedSignal("Text"):Connect(function()
            if string.find(obj.Text, LocalPlayer.Name) then
                obj.Text = ReplaceMyName(obj.Text)
            end
        end)
    end
end)

-- PAR PERSONNAGE : LOOP LÉGER SEULEMENT SUR TON PERSO (50 objets max / 2s = 0 FPS drop)
local function SetupCharacter(char)
    local head = char:WaitForChild("Head")
    
    -- Hook spécifique nametag
    head.ChildAdded:Connect(function(child)
        if child:IsA("BillboardGui") then
            child.DescendantAdded:Connect(function(desc)
                if desc:IsA("TextLabel") then
                    desc.Text = ReplaceMyName(desc.Text)
                    desc:GetPropertyChangedSignal("Text"):Connect(function()
                        desc.Text = ReplaceMyName(desc.Text)
                    end)
                end
            end)
        end
    end)
    
    -- Loop ultra-léger : scan TOUT ton perso toutes les 2s
    spawn(function()
        while char.Parent do
            wait(2)
            for _, obj in pairs(char:GetDescendants()) do
                if obj:IsA("TextLabel") and string.find(obj.Text, LocalPlayer.Name) then
                    obj.Text = ReplaceMyName(obj.Text)
                end
            end
        end
    end)
end

-- Applique actuel + futurs
if LocalPlayer.Character then
    SetupCharacter(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(SetupCharacter)

print("")
